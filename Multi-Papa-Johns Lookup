/* =========================================================================================
   Query Purpose: 
   Extracts detailed store and business information for a specific list of "Papa Johns MKT" 
   locations. It takes a comma-separated list of store numbers, matches them against the 
   dimension_store table, and deduplicates the results to ensure one record per store.
========================================================================================= */

-- CTE 1: target_stores
-- Purpose: Converts a comma-separated string of store numbers into a temporary table 
-- of individual rows, trimming any accidental whitespace.
WITH target_stores AS (
    SELECT TRIM(value) AS store_num
    FROM TABLE(SPLIT_TO_TABLE(
        'ADD STORE NUMBER HERE', -- ACTION REQUIRED: Replace this string with your target numbers (e.g., '101, 102, 103')
        ','                      -- Delimiter used to split the string
    ))
),

-- CTE 2: store_data
-- Purpose: Joins the target stores with dimension tables to gather business and region data.
store_data AS (
    SELECT
        b.business_id,
        b.DRIVE_ACCOUNT_ID,
        b.business_name,
        si.store_id,
        si.REGION_ID,
        si.STORE_ADDRESS,
        si.name        AS store_name,
        -- map.external_store_id, -- Commented out: keeping it available for future use if needed

        -- Deduplication logic: Assigns a row number to handle 1-to-many fanouts from the mapping table. 
        -- Partitioning by store_id ensures we can grab exactly 1 record per store later.
        ROW_NUMBER() OVER (
            PARTITION BY si.store_id 
            ORDER BY map.external_store_id
        ) AS rn

    FROM edw.merchant.dimension_store si
    
    -- Join to get parent business/account details
    LEFT JOIN edw.merchant.dimension_business b         
        ON b.business_id = si.business_id
        
    -- Join to get external mapping details (which might cause duplicates, hence the ROW_NUMBER above)
    LEFT JOIN edw.drive.fact_drive_store_id_mapping map 
        ON map.store_id  = si.store_id
        
    -- Filter to only include stores that match the specific naming convention of the target numbers
    WHERE si.name IN (
        SELECT 'Papa Johns MKT (' || store_num || ')'
        FROM target_stores
    )
)

-- Final SELECT
-- Purpose: Retrieves the clean, deduplicated dataset with user-friendly column headers.
SELECT
    store_name         AS "Store Name",
    store_id::TEXT     AS "Store ID",       -- Cast to TEXT to prevent accidental numerical aggregations in BI tools
    --external_store_id  AS "External Store Id",
    REGION_ID          AS "Region",
    STORE_ADDRESS      AS "Address",
    business_id::TEXT  AS "Business Id"     -- Cast to TEXT
FROM store_data

-- Filters out duplicates generated by the fact_drive_store_id_mapping join
WHERE rn = 1

-- Orders the final output numerically by store_id
ORDER BY store_id::INT ASC

-- Caps the result set at 10,001 (often used to test if results exceed a 10,000 row export limit)
LIMIT 10001;
